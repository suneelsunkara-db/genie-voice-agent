# =============================================================================
# Secrets for Genie Voice Agent. Copy to `.env`. NEVER commit the real .env.
#
# Default auth = OAuth U2M (runs AS your user) -> NO secrets needed here.
# `local-deploy.sh` runs `databricks auth login --host <host>` for you, and
# Lakebase tokens are minted at runtime. So for a normal run this file only
# matters if you switch to live STT/TTS.
# =============================================================================

# Live STT/TTS keys — prefer config/config.local.yaml `secrets:` for local dev.
# Env vars (DEEPGRAM_API_KEY, etc.) override YAML when set.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Optional config overrides (GENIE_<SECTION>__<KEY>, YAML-parsed) ---
# GENIE_DEPLOYMENT=live              # local (synthetic producer) | live (real capture)
# GENIE_DATABRICKS__HOST=https://<your-workspace>.cloud.databricks.com
# GENIE_DATABRICKS__PROFILE=<your-databricks-profile>
# GENIE_DATABRICKS__RUN_AS=user@example.com
# GENIE_DATABRICKS__CATALOG=<your-catalog>
# GENIE_DATABRICKS__SQL_WAREHOUSE_ID=<your-sql-warehouse-id>
# GENIE_LAKEBASE__INSTANCE=<your-lakebase-instance>
# GENIE_LAKEBASE__ENABLED=false

# --- Alternate auth (only if NOT using U2M; set databricks.auth_type) ---
# DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=                  # auth_type=pat
# DATABRICKS_CLIENT_ID=              # auth_type=oauth (service principal M2M)
# DATABRICKS_CLIENT_SECRET=

# --- Lakebase Postgres port (else lakebase.port in config.yaml) ---
# GENIE_LAKEBASE__PORT=5432
